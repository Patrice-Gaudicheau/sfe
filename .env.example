# SpatialFieldEngineForCognition environment example.
# Copy this file to .env and fill in local values. Do not commit .env.

# OpenAI API benchmark path.
# Set model ids to models available to your OpenAI account.
# OpenAI API and CodexCLI use separate model variables.
OPENAI_API_KEY=
OPENAI_BASE_URL=
SFE_OPENAI_ROUTER_MODEL=
SFE_OPENAI_DISCOVERY_MODEL=
SFE_OPENAI_EXECUTOR_MODEL=

# Alibaba Model Studio benchmark path.
# Uses OpenAI-compatible Chat Completions. Qwen thinking is disabled by default
# for benchmark cost/token comparability.
ALIBABA_API_KEY=
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
SFE_ALIBABA_ROUTER_MODEL=qwen3.6-flash
SFE_ALIBABA_DISCOVERY_MODEL=
SFE_ALIBABA_EXECUTOR_MODEL=qwen3.6-plus
SFE_ALIBABA_DISABLE_THINKING=true

# Google Gemini benchmark path.
# Uses Gemini's OpenAI-compatible Chat Completions endpoint.
GOOGLE_API_KEY=
SFE_GOOGLE_MODEL=gemini-2.5-flash-lite
SFE_GOOGLE_DISCOVERY_MODEL=
SFE_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Anthropic API benchmark path.
# Set model ids to models available to your Anthropic account.
# Repository benchmark defaults are documented in providers/anthropic.py:
# router claude-haiku-4-5-20251001, executor claude-sonnet-4-6.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
SFE_ANTHROPIC_ROUTER_MODEL=
SFE_ANTHROPIC_DISCOVERY_MODEL=
SFE_ANTHROPIC_EXECUTOR_MODEL=

# OpenAI CodexCLI integration path.
# /run router, discovery, TUI answers, and DEV patch proposal support:
# SFE_PROVIDER=codexcli
SFE_CODEXCLI_ROUTER_MODEL=
SFE_CODEXCLI_DISCOVERY_MODEL=
SFE_CODEXCLI_EXECUTOR_MODEL=
SFE_CODEXCLI_SANDBOX=read-only
# Role-specific effort values override SFE_CODEXCLI_REASONING_EFFORT.
SFE_CODEXCLI_ROUTER_EFFORT=
SFE_CODEXCLI_DISCOVERY_EFFORT=
SFE_CODEXCLI_EXECUTOR_EFFORT=
SFE_CODEXCLI_REASONING_EFFORT=

# Lemonade / local OpenAI-compatible inference server path.
SFE_LEMONADE_BASE_URL=http://127.0.0.1:13305
SFE_LEMONADE_API_KEY=
SFE_LEMONADE_MODEL=
# Local model ids depend on the models installed in your Lemonade server.
SFE_ROUTER_MODEL=Qwen3-0.6B-GGUF
SFE_LEMONADE_DISCOVERY_MODEL=
SFE_EXECUTOR_MODEL=Qwen3.5-35B-A3B-GGUF

# Ollama local provider path.
# Requires Ollama to be running locally and the selected model to be pulled.
SFE_OLLAMA_BASE_URL=http://localhost:11434
SFE_OLLAMA_MODEL=qwen3.5:4b
SFE_OLLAMA_ROUTER_MODEL=
SFE_OLLAMA_DISCOVERY_MODEL=
SFE_OLLAMA_EXECUTOR_MODEL=
SFE_OLLAMA_TIMEOUT_SECONDS=120
SFE_OLLAMA_THINK=false

# Live proxy shadow runners use the local Lemonade endpoint only when invoked.
SFE_PROXY_SHADOW_LIVE_TIMEOUT_SECONDS=180

# Cognitive Map LLM zone-router path.
SFE_ZONE_ROUTER_MODEL=
SFE_ZONE_ROUTER_BASE_URL=
SFE_ZONE_ROUTER_API_KEY=

# Canonical SFE provider selector.
# Used by the TUI, standby proxy, and future SFE surfaces.
SFE_PROVIDER=openai
# Optional role-specific provider selectors for SFE surfaces. Blank or absent
# values fall back to SFE_PROVIDER, then the surface default.
SFE_PROVIDER_ROUTER=
SFE_PROVIDER_DISCOVERY=
SFE_PROVIDER_EXECUTOR=

# PROXY Configuration
# Proxy mode uses this root .env file. Do not create a separate proxy env file.
# The default host binds direct local runs to loopback. The Docker compose file
# also publishes the container port on the host loopback address by default.
#
# The standby proxy keeps its existing provider semantics and uses SFE_PROVIDER
# with this precedence:
# SFE_PROVIDER > SFE_PROXY_PROVIDER legacy fallback > openai-compatible.
# SFE_PROXY_PROVIDER is kept only for legacy proxy compatibility.
#
# Generic OpenAI-compatible endpoint, default/safe option:
#SFE_PROVIDER=openai-compatible
#SFE_PROVIDER=codexcli
#SFE_PROVIDER=lemonade
#SFE_PROVIDER=alibaba
#SFE_PROVIDER=anthropic
#SFE_PROVIDER=google
#SFE_PROVIDER=ollama

# OpenAI API:
# SFE_PROVIDER=openai
#
# OpenAI CodexCLI /run router, TUI answers, and DEV patch proposals only.
# SFE validates and applies any proposed patch through its own patch machinery:
# Uses SFE_CODEXCLI_ROUTER_MODEL, SFE_CODEXCLI_DISCOVERY_MODEL, and
# SFE_CODEXCLI_EXECUTOR_MODEL. Full CodexCLI /run routing can be configured as:
# SFE_PROVIDER=codexcli
# SFE_PROVIDER_ROUTER=codexcli
# SFE_PROVIDER_DISCOVERY=codexcli
# SFE_PROVIDER_EXECUTOR=codexcli
#
# Lemonade local OpenAI-compatible server:
# SFE_PROVIDER=lemonade
#
# Alibaba Cloud Model Studio / DashScope / Qwen:
# SFE_PROVIDER=alibaba
#
# Anthropic Messages API adapter:
# SFE_PROVIDER=anthropic
#
# Google Gemini OpenAI-compatible endpoint:
# SFE_PROVIDER=google
#
# Ollama local provider:
# SFE_PROVIDER=ollama
#
# Legacy proxy-only fallback, not recommended for new configuration:
# SFE_PROXY_PROVIDER=openai-compatible
# SFE_PROXY_UPSTREAM_API_KEY is preferred when set. For the default OpenAI
# upstream, OPENAI_API_KEY can be used as the fallback upstream key.
SFE_PROXY_HOST=127.0.0.1
SFE_PROXY_PORT=17891
SFE_PROXY_MODE=pass_through
SFE_PROXY_UPSTREAM_BASE_URL=
SFE_PROXY_UPSTREAM_API_KEY=
DASHSCOPE_API_KEY=
SFE_ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode
SFE_ALIBABA_MODEL=
SFE_GOOGLE_MODEL=gemini-2.5-flash-lite
SFE_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
SFE_ANTHROPIC_API_KEY=
SFE_ANTHROPIC_BASE_URL=https://api.anthropic.com
SFE_ANTHROPIC_VERSION=2023-06-01
SFE_ANTHROPIC_MODEL=
SFE_ANTHROPIC_MAX_TOKENS=1024
SFE_ANTHROPIC_MIN_REQUEST_INTERVAL_SECONDS=0
SFE_ANTHROPIC_MAX_INPUT_CHARS=0
SFE_ANTHROPIC_RETRY_ON_RATE_LIMIT=false
SFE_ANTHROPIC_MAX_RETRY_SLEEP_SECONDS=10
SFE_PROXY_SHADOW_MIN_INPUT_TOKENS=50000
SFE_PROXY_SHADOW_LOG_DIR=logs/sfe_proxy_shadow
SFE_PROXY_SHADOW_LOG_FULL_PAYLOADS=false
SFE_PROXY_SHADOW_SELECTION_DRY_RUN=false
SFE_PROXY_SHADOW_ROUTER_DRY_RUN=false
SFE_PROXY_SHADOW_ROUTER_PROVIDER=disabled
SFE_PROXY_ENABLED_STREAMING_REPLACEMENT=false

# Optional TUI /patch JSON repair. Set false/0/no/off to disable the single
# repair attempt for JSON-like structured patch responses that fail strict JSON
# parsing.
SFE_PATCH_JSON_REPAIR_ENABLED=true

# SFE proxy provider limit decision contract for future shadow router providers.
# These settings do not call providers or affect pass-through behavior yet.
# A value of 0 means unlimited / disabled for that specific limit.
SFE_PROXY_PROVIDER_LIMITS_ENABLED=false
SFE_PROXY_PROVIDER_DEFAULT_MIN_INTERVAL_MS=0
SFE_PROXY_PROVIDER_DEFAULT_MAX_INPUT_TOKENS=0
SFE_PROXY_PROVIDER_DEFAULT_MAX_REQUESTS_PER_MINUTE=0
SFE_PROXY_PROVIDER_DEFAULT_QUEUE_MODE=reject
SFE_PROXY_OPENAI_MIN_INTERVAL_MS=0
SFE_PROXY_OPENAI_MAX_INPUT_TOKENS=0
SFE_PROXY_OPENAI_MAX_REQUESTS_PER_MINUTE=0
SFE_PROXY_OPENAI_QUEUE_MODE=reject
SFE_PROXY_ANTHROPIC_MIN_INTERVAL_MS=0
SFE_PROXY_ANTHROPIC_MAX_INPUT_TOKENS=0
SFE_PROXY_ANTHROPIC_MAX_REQUESTS_PER_MINUTE=0
SFE_PROXY_ANTHROPIC_QUEUE_MODE=reject
SFE_PROXY_LEMONADE_MIN_INTERVAL_MS=0
SFE_PROXY_LEMONADE_MAX_INPUT_TOKENS=0
SFE_PROXY_LEMONADE_MAX_REQUESTS_PER_MINUTE=0
SFE_PROXY_LEMONADE_QUEUE_MODE=reject
