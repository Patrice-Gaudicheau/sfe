# ============================================================
# Spatial Field Engine - Example configuration
# ============================================================
#
# First setup:
#   cp .env.example .env
#   choose one LLM provider below
#   uncomment its SFE_PROVIDER line
#   fill the required API key if applicable
#
# Only one SFE_PROVIDER should be active at a time.

# ------------------------------------------------------------
# LLM Provider
# ------------------------------------------------------------
# Uncomment exactly one provider:
#
#SFE_PROVIDER=openai
#SFE_PROVIDER=anthropic
#SFE_PROVIDER=google
#SFE_PROVIDER=alibaba
#SFE_PROVIDER=codexcli
#SFE_PROVIDER=lemonade
#SFE_PROVIDER=ollama

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
# Requires OPENAI_API_KEY.
#
#SFE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
SFE_OPENAI_ROUTER_MODEL=gpt-5.5
SFE_OPENAI_DISCOVERY_MODEL=
SFE_OPENAI_EXECUTOR_MODEL=gpt-5.4

# ------------------------------------------------------------
# Anthropic
# ------------------------------------------------------------
# Requires ANTHROPIC_API_KEY.
#
#SFE_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
SFE_ANTHROPIC_ROUTER_MODEL=claude-sonnet-4-6
SFE_ANTHROPIC_DISCOVERY_MODEL=
SFE_ANTHROPIC_EXECUTOR_MODEL=claude-haiku-4-5-20251001

# ------------------------------------------------------------
# Google Gemini
# ------------------------------------------------------------
# Requires GOOGLE_API_KEY. SFE_GOOGLE_MODEL is shared by router and executor.
#
#SFE_PROVIDER=google
GOOGLE_API_KEY=
SFE_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SFE_GOOGLE_MODEL=gemini-2.5
SFE_GOOGLE_DISCOVERY_MODEL=

# ------------------------------------------------------------
# Alibaba Model Studio / DashScope
# ------------------------------------------------------------
# Requires ALIBABA_API_KEY. Qwen thinking is disabled by default.
#
#SFE_PROVIDER=alibaba
ALIBABA_API_KEY=
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
SFE_ALIBABA_ROUTER_MODEL=qwen3.6-plus
SFE_ALIBABA_DISCOVERY_MODEL=
SFE_ALIBABA_EXECUTOR_MODEL=qwen3.6-plus
SFE_ALIBABA_DISABLE_THINKING=true

# ------------------------------------------------------------
# Codex CLI
# ------------------------------------------------------------
# Uses local Codex CLI authentication/configuration instead of an API key.
# The codex executable must already be installed and logged in.
#
#SFE_PROVIDER=codexcli
SFE_CODEXCLI_ROUTER_MODEL=gpt-5.5
SFE_CODEXCLI_DISCOVERY_MODEL=
SFE_CODEXCLI_EXECUTOR_MODEL=gpt-5.4
SFE_CODEXCLI_SANDBOX=read-only
SFE_CODEXCLI_ROUTER_EFFORT=
SFE_CODEXCLI_DISCOVERY_EFFORT=
SFE_CODEXCLI_EXECUTOR_EFFORT=
SFE_CODEXCLI_REASONING_EFFORT=
SFE_CODEXCLI_EXECUTOR_IDLE_TIMEOUT_SECONDS=

# ------------------------------------------------------------
# Lemonade local server
# ------------------------------------------------------------
# Uses a local OpenAI-compatible Lemonade server.
#
#SFE_PROVIDER=lemonade
SFE_LEMONADE_BASE_URL=http://127.0.0.1:13305
SFE_LEMONADE_API_KEY=
SFE_LEMONADE_MODEL=
SFE_ROUTER_MODEL=Qwen3-0.6B-GGUF
SFE_LEMONADE_DISCOVERY_MODEL=
SFE_EXECUTOR_MODEL=Qwen3.5-35B-A3B-GGUF

# ------------------------------------------------------------
# Ollama local server
# ------------------------------------------------------------
# Requires Ollama to be running locally and the selected model to be pulled.
#
#SFE_PROVIDER=ollama
SFE_OLLAMA_BASE_URL=http://localhost:11434
SFE_OLLAMA_MODEL=qwen3.5:4b
SFE_OLLAMA_ROUTER_MODEL=
SFE_OLLAMA_DISCOVERY_MODEL=
SFE_OLLAMA_EXECUTOR_MODEL=
SFE_OLLAMA_TIMEOUT_SECONDS=120
SFE_OLLAMA_THINK=false

# ------------------------------------------------------------
# Common SFE settings
# ------------------------------------------------------------
# Leave these blank unless you want different providers per role.
SFE_PROVIDER_ROUTER=
SFE_PROVIDER_DISCOVERY=
SFE_PROVIDER_EXECUTOR=

# Example 
#SFE_PROVIDER_ROUTER=openai
#SFE_PROVIDER_DISCOVERY=codexcli
#SFE_PROVIDER_EXECUTOR=anthropic

# Optional TUI /patch JSON repair. Set false/0/no/off to disable.
SFE_PATCH_JSON_REPAIR_ENABLED=true

# Workspace-write multi-pass mode for large tasks that may need several patch batches.
# The Router designs and validates the multi-pass plan; the Executor generates each batch patch.
# Values:
#   auto  = enable multi-pass only when SFE detects a task large enough to benefit from it.
#   true  = always use multi-pass for workspace_write tasks.
#   false = never use multi-pass; use a single workspace_write patch attempt.
SFE_WORKSPACE_WRITE_MULTIPASS=auto

# Maximum number of batches the Router may include in a multi-pass plan.
# Use auto to let the Router choose the pass count during planning.
SFE_MULTIPASS_MAX_PASSES=auto

# Maximum number of files each batch may modify.
SFE_MULTIPASS_MAX_FILES_PER_PASS=10


# ==========================================================================================================================
# The items below are not essential


# ------------------------------------------------------------
# Benchmark and advanced compatibility settings
# ------------------------------------------------------------
SFE_ZONE_ROUTER_MODEL=
SFE_ZONE_ROUTER_BASE_URL=
SFE_ZONE_ROUTER_API_KEY=
SFE_SEGMENT_SELECTOR_PROVIDER=
SFE_PROVIDER_IDLE_TIMEOUT_SECONDS=
SFE_PROVIDER_EXECUTOR_IDLE_TIMEOUT_SECONDS=
SFE_PROVIDER_INTERNAL_HEARTBEAT_SECONDS=
SFE_PATCH_NORMALIZE_HUNK_COUNTS=
SFE_LEMONADE_ROUTER_MODEL=
SFE_LEMONADE_EXECUTOR_MODEL=
